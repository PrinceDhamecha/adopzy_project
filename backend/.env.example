# Database (Aiven MySQL)
DB_HOST=your-project.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASSWORD=your_password
DB_NAME=pet_adoption
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# JWT
JWT_SECRET=your_jwt_secret_key_change_this

# Server
PORT=5000
NODE_ENV=development

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Images are stored locally in backend/uploads/
# Note: Render has ephemeral storage - images are lost on restart.
# For persistent image storage, consider Cloudinary (free tier available).
